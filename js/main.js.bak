        this.cometStreakMode = new CometStreakMode(this.mathEngine);
        this.galacticSpiralMode = new GalacticSpiralMode(this.mathEngine);
        this.pinprickVoidMode = new PinprickVoidMode(this.mathEngine);
        this.chronosMode = new ChronosMode(this.mathEngine);
        this.bumpTerrainMode = new BumpTerrainMode(this.mathEngine);
